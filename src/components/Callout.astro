---
/**
 * Callout / Admonition component.
 * 
 * Usage in MDX:
 *   <Callout type="warning">Content here</Callout>
 *   <Callout type="tip">Pro tip content</Callout>
 * 
 * Types: info (default), tip, warning, danger, deprecated
 * 
 * CSS classes: .callout, .callout.{type} — defined in tokens-and-components.css
 */
interface Props {
  type?: 'info' | 'tip' | 'warning' | 'danger' | 'deprecated';
}

const { type = 'info' } = Astro.props;

const icons: Record<string, string> = {
  info: '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
  tip: '<path d="M12 2L2 19.5h20L12 2z" fill="none"/><path d="M12 9v4"/><path d="M12 17h.01"/>',
  warning: '<path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><path d="M12 9v4"/><path d="M12 17h.01"/>',
  danger: '<polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/><path d="M12 8v4"/><path d="M12 16h.01"/>',
  deprecated: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
};

const labels: Record<string, string> = {
  info: 'Info',
  tip: 'Tip',
  warning: 'Warning',
  danger: 'Danger',
  deprecated: 'Deprecated',
};
---

<div class={`callout ${type}`} role="note">
  <div class="callout-header">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[type]} />
    {labels[type]}
  </div>
  <div class="callout-body">
    <slot />
  </div>
</div>
