---
/**
 * GovParamBlock — Full module parameter YAML block.
 * Used on governance/parameters page for "Example output:" sections.
 * 
 * Usage: <GovParamBlock module="application" />
 */
import govParams from '../../data/governance-params.json';

interface Props {
  module: string;
}

const { module } = Astro.props;
const mod = (govParams as any)?.modules?.[module];

function toYaml(obj: any, indent = 0): string {
  const pad = '  '.repeat(indent);
  const lines: string[] = [];
  for (const [key, value] of Object.entries(obj)) {
    if (value === null || value === undefined) {
      lines.push(`${pad}${key}: null`);
    } else if (typeof value === 'object' && !Array.isArray(value)) {
      lines.push(`${pad}${key}:`);
      lines.push(toYaml(value, indent + 1));
    } else if (typeof value === 'boolean') {
      lines.push(`${pad}${key}: ${value}`);
    } else if (typeof value === 'number') {
      lines.push(`${pad}${key}: ${value}`);
    } else {
      lines.push(`${pad}${key}: "${value}"`);
    }
  }
  return lines.join('\n');
}

const yaml = mod?.raw ? `params:\n${toYaml(mod.raw, 1)}` : `# Unable to load ${module} params`;
const fetchDate = (govParams as any)?._meta?.fetched_at?.split('T')[0] || 'unknown';
---

<div class="code-block">
  <div class="code-block-header">
    <span class="code-lang">yaml</span>
    <span style={`font-size: var(--text-xs); color: var(--text-tertiary);`}>
      Live values · fetched {fetchDate}
    </span>
  </div>
  <pre><code>{yaml}</code></pre>
</div>
